# =============================================================================
# Variables d'environnement du pipeline ELT
# =============================================================================
# Copier ce fichier en `.env` et remplacer les valeurs si besoin.
# Le fichier `.env` est gitignored — ne jamais le commiter.
# =============================================================================

# --- PostgreSQL source (données brutes ingérées par Airbyte) ---
SOURCE_POSTGRES_DB=source_db
SOURCE_POSTGRES_USER=postgres
SOURCE_POSTGRES_PASSWORD=secret

# --- PostgreSQL destination (cible Airbyte + dbt) ---
DESTINATION_POSTGRES_DB=destination_db
DESTINATION_POSTGRES_USER=postgres
DESTINATION_POSTGRES_PASSWORD=secret

# --- PostgreSQL Airflow (metadata DB) ---
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow

# --- Airflow webserver (UI login) ---
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=password
AIRFLOW_ADMIN_EMAIL=admin@airflow.com

# --- Airflow security (générer des vraies valeurs en prod !) ---
AIRFLOW_FERNET_KEY=PBNqmns_6gJ6u2AiVpYQpCJVwGH2mXa3h6H2U-MZtiY=
AIRFLOW_API_SECRET_KEY=secret
AIRFLOW_JWT_SECRET=votre_jwt_secret_partage

# --- Chemin HÔTE absolu vers le dossier dbt_transformations/ ---
# Nécessaire car le DockerOperator lance des conteneurs frères (sibling) via le socket
# Docker monté ; les chemins de volumes doivent être relatifs à l'hôte, pas au conteneur Airflow.
# Exemple : /Users/<toi>/path/to/elt-pipeline/dbt_transformations
HOST_DBT_DIR=

# --- Airbyte connection ID (à générer dans l'UI Airbyte après `abctl local install`) ---
# Voir TROUBLESHOOTING.md §14 — chaque `abctl local uninstall` invalide cet ID.
AIRBYTE_CONNECTION_ID=

# --- Airbyte credentials (récupérés via `abctl local credentials`) ---
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=
